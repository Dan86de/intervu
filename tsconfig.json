{
  "$schema": "https://raw.githubusercontent.com/Effect-TS/tsgo/refs/heads/main/schema.json",
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": false,
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ],

    // Development
    "sourceMap": true
  },
  // The browser bundles (in-iframe SDK + chrome controller) are DOM TypeScript
  // built by `Bun.build`; they typecheck under `tsconfig.browser.json` with the
  // DOM lib. The DOM-free daemon still typechecks `src/sdk/protocol.ts` through
  // its server-side import of the shared annotation types.
  "exclude": ["src/sdk", "src/chrome"]
}
